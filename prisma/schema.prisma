generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Scan {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  email           String    @default("")
  area            String    @default("") @map("location")
  problem         String
  imageData       String
  sourceUrl       String    @default("")
  formName        String    @default("hairscan-lp leads")
  telecrmStatus   String    @default("pending")
  telecrmLeadIds  String    @default("")
  telecrmResponse String    @default("")
  telecrmSyncedAt DateTime?
  createdAt       DateTime  @default(now())
}
